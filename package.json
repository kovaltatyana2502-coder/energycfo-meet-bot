{
  "name": "energycfo-meet-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Telegram bot for EnergyCFO meeting approvals.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "googleapis": "^172.0.0",
    "luxon": "^3.7.2",
    "pino": "^10.3.1",
    "telegraf": "^4.16.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "prisma": "6.19.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
